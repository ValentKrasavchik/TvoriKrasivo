generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workshop {
  id               String   @id @default(uuid())
  title            String
  description      String
  durationMinutes  Int
  capacityPerSlot  Int
  result           String
  price            Int
  imageUrl         String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  slots            Slot[]
  requests         WorkshopRequest[]
}

model Slot {
  id         String   @id @default(uuid())
  workshopId String
  workshop   Workshop @relation(fields: [workshopId], references: [id], onDelete: Restrict)
  date       String   // YYYY-MM-DD
  time       String   // HH:MM
  capacity   Int      // capacityTotal
  /// Если задано — для расчёта свободных мест на сайте вместо (сумма подтверждённых броней + offline). Иначе по факту броней.
  manualOccupiedSeats Int?
  /// Места, занятые вне записей на сайте (офлайн) — только когда manualOccupiedSeats не задан
  offlineOccupiedSeats Int @default(0)
  durationMinutes Int? // optional override (e.g. long admin hold)
  status     String   @default("OPEN") // OPEN, HELD, CANCELLED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  bookings   Booking[]
  seatHolds   SeatHold[]
  requestsConfirmed WorkshopRequest[] @relation("RequestConfirmedSlot")

  @@unique([workshopId, date, time])
}

model WorkshopRequest {
  id              String   @id @default(uuid())
  workshopId      String
  workshop        Workshop @relation(fields: [workshopId], references: [id], onDelete: Restrict)
  date            String   // YYYY-MM-DD
  time            String   // HH:MM
  name            String
  phone           String
  email           String   @default("")
  messenger       String
  participants    Int      @default(1)
  comment         String?
  status          String   @default("NEW") // NEW, CONFIRMED
  confirmedSlotId String?
  confirmedSlot   Slot?    @relation("RequestConfirmedSlot", fields: [confirmedSlotId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([date, time])
}

model Booking {
  id           String   @id @default(uuid())
  workshopId   String
  slotId       String
  slot         Slot     @relation(fields: [slotId], references: [id], onDelete: Restrict)
  name         String
  phone        String
  email        String   @default("")
  messenger    String
  participants Int      @default(1)
  comment      String?
  status       String   @default("CONFIRMED") // CONFIRMED, PENDING_ADMIN, CANCELLED, REJECTED
  reminderSentAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  seatHold     SeatHold?
}

model SeatHold {
  id              String    @id @default(uuid())
  slotId          String
  slot            Slot      @relation(fields: [slotId], references: [id], onDelete: Restrict)
  bookingId       String?   @unique
  booking         Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  participantsHeld Int
  reason          String?
  expiresAt       DateTime?
  status          String    @default("ACTIVE") // ACTIVE, RELEASED, EXPIRED
  createdAt       DateTime  @default(now())
}

model DateHold {
  id         String   @id @default(uuid())
  date       String
  workshopId String?
  reason     String?
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  name      String
  text      String
  rating    Int      @default(5)
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(uuid())
  imageUrl  String
  alt       String?
  comment   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

/// Блоки секции «Контакты» на сайте: строка с иконкой или кнопка-ссылка
model ContactBlock {
  id             String   @id @default(uuid())
  sortOrder      Int      @default(0)
  blockType      String   // FIELD | BUTTON
  label          String
  value          String?
  href           String?
  variant        String?  // primary | secondary (для BUTTON)
  iconKey        String
  customIconUrl  String?  // при iconKey = custom — URL из /api/uploads/
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Логи callback в Salebot (защита от дублей по externalLeadId + хранение request/response)
model SalebotCallback {
  id             String   @id @default(uuid())
  externalLeadId String   @unique
  leadType       String   // BOOKING | WORKSHOP_REQUEST | etc
  requestBody    String
  responseBody   String?
  httpStatus     Int?
  attempts       Int      @default(0)
  status         String   @default("PENDING") // PENDING | SENT | FAILED | SKIPPED
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
}
