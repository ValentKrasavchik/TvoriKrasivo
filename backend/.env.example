# Database (SQLite for dev; use postgres for production)
DATABASE_URL="file:./dev.db"

# Admin credentials (used for POST /api/admin/login)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_in_production

# JWT secret for admin tokens
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# CORS: allowed origin for the site (e.g. http://localhost:5173 or https://bot.epicpathfinder.ru:8443)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5500,http://localhost:3000,https://bot.epicpathfinder.ru:8443

# Optional: port (default 3001)
PORT=3001

# Unisender: UNISENDER_API_KEY из кабинета (для Unisender GO — «API-ключ» в go.unisender.ru; для классических рассылок — ключ api.unisender.com).
# Если UNISENDER_LIST_ID пуст — отправка через GO (goapi.unisender.ru, email/send.json). Если list_id задан — классический sendEmail.
UNISENDER_API_KEY=
UNISENDER_SENDER_EMAIL=
UNISENDER_SENDER_NAME=Твори Красиво
UNISENDER_LIST_ID=
# Опционально: другой дата-центр GO — https://go1.unisender.ru/ru/transactional/api/v1 или https://go2.unisender.ru/ru/transactional/api/v1
# UNISENDER_GO_BASE_URL=https://goapi.unisender.ru/ru/transactional/api/v1
# Или полный URL метода: UNISENDER_GO_SEND_URL=https://goapi.unisender.ru/ru/transactional/api/v1/email/send.json

# SMTP: запасной канал, если нет UNISENDER_API_KEY+UNISENDER_SENDER_EMAIL. Чтобы отключить SMTP: BOOKING_SMTP_ENABLED=0
# BOOKING_SMTP_ENABLED=0
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=            # или SMTP_PASSWORD (как в настройках Яндекса)
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=Твори Красиво

# Salebot: API key передаётся в URL. Если не задано, используется дефолтный callback URL из кода.
# SALEBOT_CALLBACK_URL=https://chatter.salebot.pro/api/<api_key>/callback
# SALEBOT_ENABLED=1
# SALEBOT_TIMEOUT_MS=8000
# SALEBOT_RETRY_ATTEMPTS=3
